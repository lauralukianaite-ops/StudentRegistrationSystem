                <Button fx:id="buttonAttendance" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onAttendanceClick" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: center-left; -fx-padding: 10 20 10 20;" text="Lankomumas" />
